{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Backtest Runs by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (rate(backtest_runs_total[5m]))",
          "legendFormat": "{{ status }}"
        }
      ]
    },
    {
      "title": "Celery Tasks by Name & Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (task_name, status) (rate(celery_tasks_total[5m]))",
          "legendFormat": "{{ task_name }} ({{ status }})"
        }
      ]
    },
    {
      "title": "Stale Jobs Re-dispatched (reaper)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (model) (rate(jobs_stuck_redispatched_total[5m]))",
          "legendFormat": "{{ model }}"
        }
      ]
    },
    {
      "title": "Audit Dedupe Conflicts",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "increase(audit_dedupe_conflicts_total[1h])",
          "legendFormat": "conflicts/hr"
        }
      ]
    },
    {
      "title": "Rate Limit Rejections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "sum by (bucket) (rate(rate_limit_hits_total[5m]))",
          "legendFormat": "{{ bucket }}"
        }
      ]
    },
    {
      "title": "HTTP Request Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{ path }}"
        }
      ]
    },
    {
      "title": "HTTP Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..|5..\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "title": "Stripe Webhook Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum by (event_type, result) (rate(stripe_webhook_events_total[5m]))",
          "legendFormat": "{{ event_type }} ({{ result }})"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["backtestforecast", "jobs"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "title": "BacktestForecast — Job Health",
  "uid": "bf-job-health"
}
