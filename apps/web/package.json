{
  "name": "@backtestforecast/web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --configLoader native --pool threads",
    "test:native": "vitest run --configLoader native --pool threads",
    "test:watch:native": "vitest --configLoader native --pool threads",
    "test:watch": "vitest --configLoader native --pool threads",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep-invert @fullstack",
    "test:e2e:fullstack": "playwright test --grep @fullstack",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@backtestforecast/api-client": "workspace:*",
    "@clerk/nextjs": "^6.11.3",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^15.5.12",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.1.0",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
