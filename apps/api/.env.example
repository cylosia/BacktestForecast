APP_NAME=BacktestForecast API
APP_ENV=development
APP_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000
API_PORT=8000
LOG_LEVEL=INFO
LOG_JSON=false

DATABASE_URL=postgresql+psycopg://backtestforecast:backtestforecast@localhost:5432/backtestforecast
REDIS_URL=redis://localhost:6379/0

WEB_CORS_ORIGINS=http://localhost:3000
API_ALLOWED_HOSTS=localhost,127.0.0.1
REQUEST_MAX_BODY_BYTES=1048576
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

CLERK_SECRET_KEY=
CLERK_ISSUER=
CLERK_AUDIENCE=
CLERK_JWKS_URL=
CLERK_JWT_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_PREMIUM_MONTHLY_PRICE_ID=
STRIPE_PREMIUM_YEARLY_PRICE_ID=

MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
MASSIVE_TIMEOUT_SECONDS=30
MASSIVE_MAX_RETRIES=2
MASSIVE_RETRY_BACKOFF_SECONDS=0.5
# Earnings calendar API key (used for the "avoid earnings" entry rule).
# When absent, the earnings avoidance rule is silently skipped.
EARNINGS_API_KEY=

RATE_LIMIT_PREFIX=bff:rate-limit
BACKTEST_CREATE_RATE_LIMIT=10
SCAN_CREATE_RATE_LIMIT=6
EXPORT_CREATE_RATE_LIMIT=20
BILLING_CREATE_RATE_LIMIT=10
RATE_LIMIT_WINDOW_SECONDS=60

MAX_BACKTEST_WINDOW_DAYS=1825
MAX_SCANNER_WINDOW_DAYS=730

S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
